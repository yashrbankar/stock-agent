APP_NAME=Stock Bot
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO

GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

GEMINI_MODEL=gemini-2.5-flash
GEMINI_BATCH_SIZE=5

NSE_INDEX_NAME=NIFTY TOTAL MARKET
SCREEN_LIMIT=40
LOOKBACK_DAYS=370
FILTER_NEAR_WKL_PCT=5
BUCKET_1_NEAR_WKL_PCT=5
BUCKET_2_NEAR_WKL_PCT=10
BUCKET_3_NEAR_WKL_PCT=20
FILTER_MAX_PE=25
FILTER_MAX_PB=3
FILTER_MAX_DEBT_TO_EQUITY=1
FILTER_MAX_30D_CHANGE=-0.01

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@example.com
EMAIL_TO=recipient@example.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

SCHEDULE_HOUR=8
SCHEDULE_MINUTE=30
